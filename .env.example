# Supabase (shared auth)
SUPABASE_URL=http://host.docker.internal:8001
SUPABASE_JWT_SECRET=your-jwt-secret-here
SUPABASE_ANON_KEY=your-anon-key-here

# AI / OpenRouter (shared across apps)
OPENROUTER_API_KEY=sk-or-v1-...

# Stripe (Launchpad credit authority)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Internal credit API (apps proxy to Launchpad backend)
LAUNCHPAD_URL=http://launchpad-backend:8000

# App-specific
DB_PATH=/app/data/app.db
